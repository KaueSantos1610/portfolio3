#include <stdio.h>
#include <string.h>

struct Venda {
    char produto[50];
    int quantidade;
    float valorUnitario;
    float total;
};

struct Venda vendas[50];

int quantidadeVendas = 0;

float calcularTotal(int qtd, float valor) {
    return qtd * valor;
}

void cadastrarVenda() {

    printf("\nNome do produto: ");
    scanf(" %[^\n]", vendas[quantidadeVendas].produto);

    printf("Quantidade vendida: ");
    scanf("%d", &vendas[quantidadeVendas].quantidade);

    printf("Valor unitario: ");
    scanf("%f", &vendas[quantidadeVendas].valorUnitario);

    vendas[quantidadeVendas].total = calcularTotal(
        vendas[quantidadeVendas].quantidade,
        vendas[quantidadeVendas].valorUnitario
    );

    if(vendas[quantidadeVendas].total > 100) {
        vendas[quantidadeVendas].total =
        vendas[quantidadeVendas].total - (vendas[quantidadeVendas].total * 0.10);

        printf("Desconto de 10%% aplicado!\n");
    }

    printf("Venda cadastrada com sucesso!\n");

    quantidadeVendas++;
}

void listarVendas() {

    int i;
    float totalGeral = 0;

    if(quantidadeVendas == 0) {
        printf("\nNenhuma venda cadastrada.\n");
    }
    else {

        printf("\n===== LISTA DE VENDAS =====\n");

        for(i = 0; i < quantidadeVendas; i++) {

            printf("\nVenda %d\n", i + 1);
            printf("Produto: %s\n", vendas[i].produto);
            printf("Quantidade: %d\n", vendas[i].quantidade);
            printf("Valor unitario: %.2f\n", vendas[i].valorUnitario);
            printf("Total da venda: %.2f\n", vendas[i].total);

            totalGeral = totalGeral + vendas[i].total;
        }

        printf("\nTotal geral vendido: %.2f\n", totalGeral);
    }
}

int main() {

    int opcao = 0;

    while(opcao != 3) {

        printf("\n===== MENU =====\n");
        printf("1 - Cadastrar venda\n");
        printf("2 - Listar vendas\n");
        printf("3 - Sair\n");
        printf("Escolha uma opcao: ");
        scanf("%d", &opcao);

        switch(opcao) {

            case 1:
                cadastrarVenda();
                break;

            case 2:
                listarVendas();
                break;

            case 3:
                printf("Programa encerrado.\n");
                break;

            default:
                printf("Opcao invalida.\n");
        }
    }

    return 0;
}

#include <stdio.h>
#include <string.h>

struct Livro {
    char titulo[50];
    char autor[50];
    int ano;
    int quantidade;
};

struct Livro livros[50];

int quantidadeLivros = 0;

void cadastrarLivro() {

    printf("\nTitulo do livro: ");
    scanf(" %[^\n]", livros[quantidadeLivros].titulo);

    printf("Autor do livro: ");
    scanf(" %[^\n]", livros[quantidadeLivros].autor);

    printf("Ano de publicacao: ");
    scanf("%d", &livros[quantidadeLivros].ano);

    printf("Quantidade disponivel: ");
    scanf("%d", &livros[quantidadeLivros].quantidade);

    printf("Livro cadastrado com sucesso!\n");

    quantidadeLivros++;
}

void listarLivros() {

    int i;

    if(quantidadeLivros == 0) {

        printf("\nNenhum livro cadastrado.\n");
    }
    else {

        printf("\n===== LISTA DE LIVROS =====\n");

        for(i = 0; i < quantidadeLivros; i++) {

            printf("\nLivro %d\n", i + 1);
            printf("Titulo: %s\n", livros[i].titulo);
            printf("Autor: %s\n", livros[i].autor);
            printf("Ano: %d\n", livros[i].ano);
            printf("Quantidade: %d\n", livros[i].quantidade);

            if(livros[i].quantidade > 0) {
                printf("Status: Disponivel\n");
            }
            else {
                printf("Status: Indisponivel\n");
            }
        }
    }
}

void buscarLivrosAno() {

    int anoBusca;
    int i;

    printf("\nMostrar livros publicados apos qual ano? ");
    scanf("%d", &anoBusca);

    printf("\n===== RESULTADO =====\n");

    for(i = 0; i < quantidadeLivros; i++) {

        if(livros[i].ano > anoBusca) {

            printf("\nTitulo: %s\n", livros[i].titulo);
            printf("Autor: %s\n", livros[i].autor);
            printf("Ano: %d\n", livros[i].ano);
        }
    }
}

int main() {

    int opcao = 0;

    while(opcao != 4) {

        printf("\n===== MENU =====\n");
        printf("1 - Cadastrar livro\n");
        printf("2 - Listar livros\n");
        printf("3 - Buscar livros por ano\n");
        printf("4 - Sair\n");
        printf("Escolha uma opcao: ");
        scanf("%d", &opcao);

        switch(opcao) {

            case 1:
                cadastrarLivro();
                break;

            case 2:
                listarLivros();
                break;

            case 3:
                buscarLivrosAno();
                break;

            case 4:
                printf("Programa encerrado.\n");
                break;

            default:
                printf("Opcao invalida.\n");
        }
    }

    return 0;
}
